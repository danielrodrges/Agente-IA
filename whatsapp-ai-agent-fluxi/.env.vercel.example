# ============================================
# Variáveis de Ambiente para Deploy na Vercel
# ============================================
# Configure estas variáveis no painel da Vercel:
# Settings > Environment Variables

# ---- OBRIGATÓRIO ----

# URL do banco PostgreSQL (Supabase)
# Formato: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:SUA_SENHA@db.XXXX.supabase.co:5432/postgres

# ---- LLM (pelo menos um) ----

# Anthropic (Claude) - Recomendado para o agente Sofia
ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter (alternativa multi-modelo)
# OPENROUTER_API_KEY=sk-or-...

# OpenAI (para embeddings RAG)
# OPENAI_API_KEY=sk-...

# ---- WHATSAPP META API ----
# Configure na interface web após o deploy
# META_PHONE_NUMBER_ID=
# META_ACCESS_TOKEN=
# META_VERIFY_TOKEN=
# META_APP_SECRET=

# ---- SISTEMA ----

# Detectado automaticamente pela Vercel
# VERCEL=1

# Segredo para sessões web (gere um aleatório)
SESSION_SECRET_KEY=mude-para-um-segredo-forte-aqui

# Debug (false em produção)
DEBUG=false
